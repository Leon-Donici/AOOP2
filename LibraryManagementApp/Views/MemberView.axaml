<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LibraryManagementApp.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="600"
             x:Class="LibraryManagementApp.Views.MemberView"
             x:DataType="vm:MemberViewModel">

    <DockPanel>
        <!-- Header bar -->
        <Border DockPanel.Dock="Top" Background="#1565C0" Padding="16,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Logout"
                        Command="{Binding LogoutCommand}"
                        Padding="14,7" FontSize="13"/>
                <TextBlock Text="{Binding WelcomeMessage}"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Padding="16,8"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                       Foreground="#2e7d32" FontWeight="SemiBold"/>
        </Border>

        <!-- Tabs -->
        <TabControl Margin="12,8,12,4" FontSize="14">

            <!-- ==================== Library Catalog ==================== -->
            <TabItem Header="Library Catalog" FontSize="14">
                <DockPanel Margin="4,12,4,4">
                    <!-- Search -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                        <TextBox Text="{Binding SearchQuery}"
                                 Watermark="Search by title, author, or ISBN..."
                                 Width="420" Padding="10,8" FontSize="13"/>
                        <Button Content="Search" Command="{Binding SearchCommand}"
                                Padding="16,8" FontSize="13"/>
                    </StackPanel>

                    <!-- Details panel (right side) -->
                    <Border DockPanel.Dock="Right" Width="280"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                            CornerRadius="6" Padding="16" Margin="12,0,0,0"
                            IsVisible="{Binding SelectedBook, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Book Details" FontSize="17" FontWeight="Bold"
                                       Margin="0,0,0,4"/>
                            <Separator/>
                            <TextBlock Text="{Binding SelectedBook.Title}"
                                       FontWeight="SemiBold" FontSize="15"
                                       TextWrapping="Wrap"/>
                            <TextBlock TextWrapping="Wrap" FontSize="13">
                                <Run Text="Author: " FontWeight="SemiBold"/>
                                <Run Text="{Binding SelectedBook.Author}"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="13">
                                <Run Text="ISBN: " FontWeight="SemiBold"/>
                                <Run Text="{Binding SelectedBook.Isbn}"/>
                            </TextBlock>
                            <Separator Margin="0,4"/>
                            <TextBlock Text="{Binding SelectedBook.Description}"
                                       TextWrapping="Wrap" FontSize="12.5"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       MaxHeight="120"/>
                            <Button Content="Borrow This Book"
                                    Command="{Binding BorrowBookCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Padding="10,10" FontSize="14"
                                    Margin="0,8,0,0"
                                    Classes="accent"/>
                        </StackPanel>
                    </Border>

                    <!-- Book list (fills remaining) -->
                    <ListBox ItemsSource="{Binding AvailableBooks}"
                             SelectedItem="{Binding SelectedBook}"
                             Padding="2">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,10" Margin="0,1">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Text="{Binding Author, StringFormat='by {0}'}"
                                                   FontSize="12.5"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>

            <!-- ==================== My Loans ==================== -->
            <TabItem Header="My Loans" FontSize="14">
                <Grid Margin="4,12,4,4" RowDefinitions="Auto,*,Auto,Auto">

                    <!-- Active loans header -->
                    <TextBlock Grid.Row="0" Text="Currently Borrowed Books"
                               FontSize="17" FontWeight="Bold" Margin="0,0,0,10"/>

                    <!-- Active loans list -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding ActiveLoans}" Padding="2">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="6,8">
                                    <Button DockPanel.Dock="Right" Content="Return"
                                            Command="{Binding $parent[UserControl].((vm:MemberViewModel)DataContext).ReturnBookCommand}"
                                            CommandParameter="{Binding}"
                                            Padding="14,8" Margin="12,0,0,0"
                                            FontSize="13" VerticalAlignment="Center"/>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding BookTitle}"
                                                   FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Text="{Binding BookAuthor, StringFormat='by {0}'}"
                                                   FontSize="12.5"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Text="{Binding BorrowDate, StringFormat='Borrowed: {0:yyyy-MM-dd}'}"
                                                   FontSize="11.5"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- History header -->
                    <TextBlock Grid.Row="2" Text="Borrowing History"
                               FontSize="17" FontWeight="Bold" Margin="0,16,0,10"/>

                    <!-- History table -->
                    <DataGrid Grid.Row="3" ItemsSource="{Binding BorrowingHistory}"
                              IsReadOnly="True" AutoGenerateColumns="False"
                              MaxHeight="220" MinHeight="80"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                              CornerRadius="4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Book" Binding="{Binding BookTitle}" Width="*"/>
                            <DataGridTextColumn Header="Author" Binding="{Binding BookAuthor}" Width="*"/>
                            <DataGridTextColumn Header="Borrowed" Binding="{Binding BorrowDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="110"/>
                            <DataGridTextColumn Header="Returned" Binding="{Binding ReturnDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
